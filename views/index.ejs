<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DaOrden - Control de Asistencia</title>
    <link rel="stylesheet" href="/lista/style.css">
    <style>
        /* Estilos existentes omitidos por brevedad y añadidos al style.css o aquí */
        .stats-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 1.5rem;
            margin-bottom: 2rem;
        }
        
        .stat-card {
            background: var(--card-bg);
            backdrop-filter: blur(12px);
            border: 1px solid var(--border-color);
            border-radius: 15px;
            padding: 1.5rem;
            text-align: center;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 120px;
        }
        
        .stat-value {
            font-size: 3rem;
            font-weight: 600;
            color: var(--accent-color);
            line-height: 1;
        }
        
        .stat-label {
            font-size: 0.9rem;
            color: var(--text-secondary);
            text-transform: uppercase;
            letter-spacing: 0.1em;
            margin-top: 0.5rem;
        }

        .checkbox-wrapper {
            position: relative;
            display: inline-block;
            width: 24px;
            height: 24px;
        }

        .checkbox-wrapper input {
            opacity: 0;
            width: 0;
            height: 0;
        }

        .checkmark {
            position: absolute;
            top: 0;
            left: 0;
            height: 24px;
            width: 24px;
            background-color: rgba(255, 255, 255, 0.1);
            border: 2px solid var(--border-color);
            border-radius: 6px;
            transition: all 0.2s ease;
            cursor: pointer;
        }

        .checkbox-wrapper input:checked ~ .checkmark {
            background-color: var(--accent-color);
            border-color: var(--accent-color);
            box-shadow: 0 0 10px rgba(56, 189, 248, 0.4);
        }

        .checkmark:after {
            content: "";
            position: absolute;
            display: none;
            left: 7px;
            top: 3px;
            width: 5px;
            height: 10px;
            border: solid white;
            border-width: 0 2px 2px 0;
            transform: rotate(45deg);
        }

        .checkbox-wrapper input:checked ~ .checkmark:after {
            display: block;
        }
        
        .person-name {
            font-size: 1.2rem;
            font-weight: 500;
            margin-right: 15px;
        }
        
        .status-text {
            font-size: 0.8rem;
            color: var(--text-secondary);
            margin-left: 10px;
            display: flex;
            align-items: center;
        }
        
        .order-info {
            display: flex;
            align-items: center;
            flex-grow: 1;
        }

        /* Nuevos estilos */
        .controls-wrapper {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .btn-delete {
            background: none;
            border: none;
            color: #ef4444;
            cursor: pointer;
            padding: 5px;
            opacity: 0.6;
            transition: opacity 0.2s;
            font-size: 1.2rem;
        }
        .btn-delete:hover {
            opacity: 1;
        }

        .add-form {
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .add-input {
            flex-grow: 1;
            padding: 0.8rem;
            background: rgba(15, 23, 42, 0.5);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            color: var(--text-primary);
            font-family: inherit;
        }
        .add-input:focus {
            outline: none;
            border-color: var(--accent-color);
        }
        .add-btn {
            padding: 0.8rem 1.5rem;
            background: rgba(56, 189, 248, 0.2);
            color: var(--accent-color);
            border: 1px solid rgba(56, 189, 248, 0.3);
            border-radius: 8px;
            cursor: pointer;
            font-weight: 600;
            transition: all 0.2s;
        }
        .add-btn:hover {
            background: rgba(56, 189, 248, 0.3);
        }

        .header-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 2rem;
            padding-bottom: 1rem;
            border-bottom: 1px solid var(--border-color);
        }
        .user-info {
            display: flex;
            align-items: center;
            gap: 15px;
        }
        .logout-btn {
            background: none;
            border: 1px solid var(--border-color);
            color: var(--text-secondary);
            padding: 5px 10px;
            border-radius: 5px;
            cursor: pointer;
            font-size: 0.8rem;
        }
        .logout-btn:hover {
            background: rgba(255,255,255,0.05);
            color: white;
        }
        .alert {
            padding: 1rem;
            border-radius: 8px;
            margin-bottom: 1rem;
        }
        .alert-success {
            background: rgba(16, 185, 129, 0.1);
            color: #10b981;
            border: 1px solid rgba(16, 185, 129, 0.2);
        }
    </style>
</head>
<body>
    <div class="container">
        
        <div class="header-bar">
            <h1 style="margin: 0; font-size: 1.8rem;">Control de Asistencia</h1>
            <div class="user-info">
                <span style="color: var(--text-secondary); font-size: 0.9rem;">Hola, <%= username %></span>
                <form action="/lista/logout" method="POST" style="margin: 0;">
                    <button type="submit" class="logout-btn">Salir</button>
                </form>
            </div>
        </div>

        <% if (locals.success && success.length > 0) { %>
            <div class="alert alert-success"><%= success %></div>
        <% } %>
        <% if (locals.error) { %>
            <div class="alert" style="background: rgba(239, 68, 68, 0.1); color: #ef4444;"><%= error %></div>
        <% } %>

        <div class="stats-grid">
            <div class="stat-card">
                <div id="attendees-count" class="stat-value"><%= attendeesCount %></div>
                <div class="stat-label">Personas Presentes</div>
            </div>
        </div>

        <div class="card" style="margin-bottom: 2rem;">
            <form class="add-form" action="/lista/add-person" method="POST">
                <input type="text" name="name" class="add-input" placeholder="Añadir nueva persona..." required>
                <button type="submit" class="add-btn">+ Añadir</button>
            </form>
        </div>

        <div class="card" style="margin-bottom: 2rem;">
            <div class="add-form"> <div style="position: relative; flex-grow: 1; display: flex; align-items: center;">
                    <span style="position: absolute; left: 15px; color: var(--accent-color); font-size: 1.1rem; pointer-events: none;">🔍</span>
                    <input type="text"
                           id="attendee-search"
                           class="add-input"
                           placeholder="Buscar asistente"
                           onkeyup="filterList()"
                           style="padding-left: 45px; width: 100%;"> </div>
            </div>
        </div>
        
        <div class="card">
            <% if (people.length === 0) { %>
                <p style="text-align: center; color: var(--text-secondary);">No hay personas en la lista.</p>
            <% } else { %>
                <ul class="order-list">
                    <% people.forEach(person => { %>
                        <li class="order-item" id="item-<%= person.id %>">
                            <div class="order-info">
                                <span class="person-name"><%= person.name %></span>
                                <span id="status-<%= person.id %>" class="status-text" style="color: <%= person.present ? '#10b981' : '#94a3b8' %>">
                                    <%= person.present ? 'Presente' : 'Ausente' %>
                                </span>
                            </div>
                            
                            <div class="controls-wrapper">
                                <label class="checkbox-wrapper">
                                    <input type="checkbox" 
                                           onchange="togglePresence(<%= person.id %>, this.checked)" 
                                           <%= person.present ? 'checked' : '' %>>
                                    <span class="checkmark"></span>
                                </label>
                                
                                <button class="btn-delete" onclick="deletePerson(<%= person.id %>, '<%= person.name %>')" title="Eliminar persona">
                                    &times;
                                </button>
                            </div>
                        </li>
                    <% }) %>
                </ul>
            <% } %>
        </div>
        
        <div style="margin-top: 2rem; text-align: center;">
            <p style="font-size: 0.8rem; color: var(--text-secondary);">Sincronizado con MariaDB (Protegido)</p>
        </div>
    </div>

    <script>
        async function togglePresence(id, isChecked) {
            const statusLabel = document.getElementById(`status-${id}`);
            const attendeesCountEl = document.getElementById('attendees-count');
            const originalText = statusLabel.innerText;
            
            // Actualización visual inmediata (optimista)
            let currentCount = parseInt(attendeesCountEl.innerText);
            attendeesCountEl.innerText = isChecked ? currentCount + 1 : currentCount - 1;
            statusLabel.innerText = isChecked ? 'Sincronizando...' : 'Sincronizando...';
            
            try {
                const response = await fetch('/lista/update-presence', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({ id, present: isChecked }),
                    credentials: 'same-origin'
                });
                
                const result = await response.json();
                if (result.success) {
                    statusLabel.innerText = isChecked ? 'Presente' : 'Ausente';
                    statusLabel.style.color = isChecked ? '#10b981' : '#94a3b8';
                } else {
                    const errorMsg = result.errors ? result.errors.map(e => e.msg).join(', ') : (result.error || 'Desconocido');
                    alert('Error del servidor: ' + errorMsg);
                    // Revertimos contador si falla
                    attendeesCountEl.innerText = isChecked ? currentCount : currentCount;
                    statusLabel.innerText = originalText;
                    document.getElementById(`item-${id}`).querySelector('input[type="checkbox"]').checked = !isChecked; // Revertir checkbox también
                }
            } catch (error) {
                console.error('Error:', error);
                alert('No se pudo conectar con el servidor o error de red: ' + error.message);
                // Revertimos contador si falla
                attendeesCountEl.innerText = currentCount;
                statusLabel.innerText = originalText;
                document.getElementById(`item-${id}`).querySelector('input[type="checkbox"]').checked = !isChecked; // Revertir checkbox
            }
        }

        function filterList() {
            const input = document.getElementById('attendee-search');
            const filter = input.value.toLowerCase();
            const listItems = document.querySelectorAll('.order-item');

            listItems.forEach(item => {
                const name = item.querySelector('.person-name').innerText.toLowerCase();
                if (name.includes(filter)) {
                    item.style.display = "";
                } else {
                    item.style.display = "none";
                }
            });
        }

        async function deletePerson(id, name) {
            if (!confirm(`¿Estás seguro de que deseas eliminar a "${name}" de la lista?`)) {
                return;
            }

            try {
                const response = await fetch(`/lista/delete-person/${id}`, {
                    method: 'DELETE',
                });
                
                const result = await response.json();
                if (result.success) {
                    // Refrescar página para recalcular conteos
                    window.location.reload();
                } else {
                    alert('Error al eliminar: ' + (result.error || 'Desconocido'));
                }
            } catch (error) {
                console.error('Error:', error);
                alert('No se pudo conectar con el servidor');
            }
        }
    </script>
</body>
</html>
